# Maintainer: onjoakimsmind
pkgname=pipemeeter
pkgver=0.1.0
pkgrel=1
pkgdesc="A native Linux audio mixer built with Rust, Dioxus and PipeWire"
arch=('x86_64' 'aarch64')
url="https://github.com/onjoakimsmind/pipemeeter"
license=('MIT')
depends=('pipewire' 'pipewire-pulse' 'webkit2gtk-4.1' 'gtk3')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/onjoakimsmind/$pkgname/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --locked --features "desktop-ui system-audio"
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 target/release/pipemeeter "$pkgdir/usr/bin/pipemeeter"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 packaging/pipemeeter.desktop "$pkgdir/usr/share/applications/pipemeeter.desktop"
    install -Dm644 pipemeeter.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/pipemeeter.svg"
}
